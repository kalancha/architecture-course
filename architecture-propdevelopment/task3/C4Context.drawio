<mxfile host="app.diagrams.net">
  <diagram name="C4 Context - Smart Home">
    <mxGraphModel dx="2800" dy="2000" grid="1" gridSize="10">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <object placeholders="1" c4Name="Собственник" c4Type="Person" c4Description="Владелец квартиры в ЖК PropDevelopment. Управляет доступом в дом и на парковку через мобильное приложение" label="&lt;font style='font-size: 16px'&gt;&lt;b&gt;%c4Name%&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[%c4Type%]&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;font style='font-size: 11px'&gt;&lt;font color='#cccccc'&gt;%c4Description%&lt;/font&gt;&lt;/div&gt;" id="person_owner">
          <mxCell style="html=1;fontSize=11;dashed=0;whiteSpace=wrap;fillColor=#083F75;strokeColor=#06315C;fontColor=#ffffff;shape=mxgraph.c4.person2;align=center;metaEdit=1;points=[[0.5,0,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0]];resizable=0;" vertex="1" parent="1">
            <mxGeometry x="550" y="20" width="200" height="180" as="geometry"/>
          </mxCell>
        </object>

        <object placeholders="1" c4Name="Гость / Посетитель" c4Type="Person" c4Description="Посетитель ЖК: курьер, гость собственника. Взаимодействует с домофоном" label="&lt;font style='font-size: 16px'&gt;&lt;b&gt;%c4Name%&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[%c4Type%]&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;font style='font-size: 11px'&gt;&lt;font color='#cccccc'&gt;%c4Description%&lt;/font&gt;&lt;/div&gt;" id="person_guest">
          <mxCell style="html=1;fontSize=11;dashed=0;whiteSpace=wrap;fillColor=#08427B;strokeColor=#06315C;fontColor=#ffffff;shape=mxgraph.c4.person2;align=center;metaEdit=1;points=[[0.5,0,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0]];resizable=0;" vertex="1" parent="1">
            <mxGeometry x="150" y="20" width="200" height="180" as="geometry"/>
          </mxCell>
        </object>

        <object placeholders="1" c4Name="Администратор УК" c4Type="Person" c4Description="Сотрудник управляющей компании. Управляет списками доступа, просматривает журнал событий" label="&lt;font style='font-size: 16px'&gt;&lt;b&gt;%c4Name%&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[%c4Type%]&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;font style='font-size: 11px'&gt;&lt;font color='#cccccc'&gt;%c4Description%&lt;/font&gt;&lt;/div&gt;" id="person_admin">
          <mxCell style="html=1;fontSize=11;dashed=0;whiteSpace=wrap;fillColor=#08427B;strokeColor=#06315C;fontColor=#ffffff;shape=mxgraph.c4.person2;align=center;metaEdit=1;points=[[0.5,0,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0]];resizable=0;" vertex="1" parent="1">
            <mxGeometry x="950" y="20" width="200" height="180" as="geometry"/>
          </mxCell>
        </object>

        <object placeholders="1" c4Name="PropDevelopment" c4Type="Software System" c4Description="Экосистема PropDevelopment: мобильное приложение для собственников, CRM, сервисы ЖКУ, управление доступом в «Умный дом»" label="&lt;font style='font-size: 16px'&gt;&lt;b&gt;%c4Name%&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[%c4Type%]&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;font style='font-size: 11px'&gt;&lt;font color='#cccccc'&gt;%c4Description%&lt;/font&gt;&lt;/div&gt;" id="sys_prop">
          <mxCell style="rounded=1;whiteSpace=wrap;html=1;labelBackgroundColor=none;fillColor=#438DD5;fontColor=#ffffff;align=center;arcSize=10;strokeColor=#3C7FC0;metaEdit=1;resizable=0;points=[[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0.25,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0],[0,0.25,0]];" vertex="1" parent="1">
            <mxGeometry x="480" y="350" width="340" height="150" as="geometry"/>
          </mxCell>
        </object>

        <object placeholders="1" c4Name="Платформа «Умный дом» (Партнёр)" c4Type="Software System" c4Description="Внешняя платформа партнёра: управление интеллектуальным домофоном и шлагбаумом, распознавание лиц и номеров" label="&lt;font style='font-size: 16px'&gt;&lt;b&gt;%c4Name%&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[%c4Type%]&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;font style='font-size: 11px'&gt;&lt;font color='#cccccc'&gt;%c4Description%&lt;/font&gt;&lt;/div&gt;" id="sys_partner">
          <mxCell style="rounded=1;whiteSpace=wrap;html=1;labelBackgroundColor=none;fillColor=#8C8496;fontColor=#ffffff;align=center;arcSize=10;strokeColor=#736782;metaEdit=1;resizable=0;points=[[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0.25,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0],[0,0.25,0]];" vertex="1" parent="1">
            <mxGeometry x="480" y="650" width="340" height="150" as="geometry"/>
          </mxCell>
        </object>

        <object placeholders="1" c4Name="IoT-устройства ЖК" c4Type="Software System" c4Description="Физические устройства: камеры домофонов с распознаванием лиц, камеры шлагбаумов с распознаванием номеров, контроллеры замков" label="&lt;font style='font-size: 16px'&gt;&lt;b&gt;%c4Name%&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[%c4Type%]&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;font style='font-size: 11px'&gt;&lt;font color='#cccccc'&gt;%c4Description%&lt;/font&gt;&lt;/div&gt;" id="sys_iot">
          <mxCell style="rounded=1;whiteSpace=wrap;html=1;labelBackgroundColor=none;fillColor=#8C8496;fontColor=#ffffff;align=center;arcSize=10;strokeColor=#736782;metaEdit=1;resizable=0;points=[[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0.25,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0],[0,0.25,0]];" vertex="1" parent="1">
            <mxGeometry x="50" y="650" width="300" height="150" as="geometry"/>
          </mxCell>
        </object>

        <object placeholders="1" c4Name="Сервис биометрии" c4Type="Software System" c4Description="Внешний или встроенный в платформу партнёра сервис для обработки биометрических данных (распознавание лиц)" label="&lt;font style='font-size: 16px'&gt;&lt;b&gt;%c4Name%&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[%c4Type%]&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;font style='font-size: 11px'&gt;&lt;font color='#cccccc'&gt;%c4Description%&lt;/font&gt;&lt;/div&gt;" id="sys_biometry">
          <mxCell style="rounded=1;whiteSpace=wrap;html=1;labelBackgroundColor=none;fillColor=#8C8496;fontColor=#ffffff;align=center;arcSize=10;strokeColor=#736782;metaEdit=1;resizable=0;points=[[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0.25,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0],[0,0.25,0]];" vertex="1" parent="1">
            <mxGeometry x="920" y="650" width="300" height="150" as="geometry"/>
          </mxCell>
        </object>

        <mxCell id="e1" edge="1" parent="1" source="person_owner" target="sys_prop" style="rounded=1;strokeColor=#707070;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e1_label" value="Управляет доступом в дом&#xa;и на парковку, просматривает&#xa;видео с домофона, добавляет&#xa;авто и лица для распознавания&#xa;[HTTPS, Mobile App]" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;" connectable="0" vertex="1" parent="e1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e2" edge="1" parent="1" source="person_guest" target="sys_iot" style="rounded=1;strokeColor=#707070;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e2_label" value="Звонит в домофон,&#xa;распознаётся камерой&#xa;[Физическое взаимодействие]" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;" connectable="0" vertex="1" parent="e2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e3" edge="1" parent="1" source="person_admin" target="sys_prop" style="rounded=1;strokeColor=#707070;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e3_label" value="Управляет глобальными&#xa;списками доступа,&#xa;просматривает журнал событий&#xa;[HTTPS, Web]" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;" connectable="0" vertex="1" parent="e3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e4" edge="1" parent="1" source="sys_prop" target="sys_partner" style="rounded=1;strokeColor=#707070;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e4_label" value="Передаёт списки доступа&#xa;(разрешённые лица, номера авто).&#xa;Получает события (звонки,&#xa;проходы, проезды).&#xa;Команды открытия двери/шлагбаума&#xa;[REST API, OAuth 2.0, TLS 1.3]" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;" connectable="0" vertex="1" parent="e4">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e5" edge="1" parent="1" source="sys_iot" target="sys_partner" style="rounded=1;strokeColor=#707070;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e5_label" value="Передаёт видеопоток,&#xa;события звонков, фото лиц,&#xa;фото номеров.&#xa;Получает команды управления&#xa;[MQTT/TLS, RTSP]" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;" connectable="0" vertex="1" parent="e5">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e6" edge="1" parent="1" source="sys_partner" target="sys_biometry" style="rounded=1;strokeColor=#707070;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e6_label" value="Отправляет фото для&#xa;распознавания лиц.&#xa;Получает результат&#xa;идентификации&#xa;[REST API, mTLS]" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;" connectable="0" vertex="1" parent="e6">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e7" edge="1" parent="1" source="person_owner" target="sys_iot" style="rounded=1;strokeColor=#707070;strokeWidth=1;dashed=1;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e7_label" value="Распознаётся камерой&#xa;домофона/шлагбаума&#xa;[Физическое взаимодействие]" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;" connectable="0" vertex="1" parent="e7">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
