        </mxCell>
        <mxCell id="sec_d6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0e6f6;fontSize=11;" value="Ключи управления&#xa;«Умным домом»: управление&#xa;замками, автоматикой" vertex="1">
          <mxGeometry height="60" width="260" x="1820" y="1150" as="geometry" />
        </mxCell>
