        </mxCell>
        <mxCell id="sec_d7" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0e6f6;fontSize=11;" value="JDBC credentials для всех&#xa;баз данных (PostgreSQL, MSSQL)" vertex="1">
          <mxGeometry height="50" width="260" x="1820" y="1230" as="geometry" />
        </mxCell>
        <mxCell id="q-YAQTcvxLUxt3pqkwpD-53" edge="1" parent="1" source="cat_sec" style="strokeColor=#9673a6;" target="sec_d7">
