        </mxCell>
        <mxCell id="sec_d5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0e6f6;fontSize=11;" value="API-ключи партнёров&#xa;(управляющие компании ЖКХ)&#xa;— без единых политик!" vertex="1">
