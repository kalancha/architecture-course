        <mxCell id="q-YAQTcvxLUxt3pqkwpD-36" edge="1" parent="1" source="cat_conf" style="strokeColor=#b85450;strokeWidth=2;" target="conf_r1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="conf_r1_why" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffee;fontSize=10;" value="1) API партнёров передают ПДн явно&#xa;2) Партнёр одной УК видит данные другой&#xa;3) У конкурента уже была утечка в СМИ&#xa;4) ФЗ-152: штрафы до 18 млн руб.&#xa;5) Компрометация замков → физическая&#xa;   угроза безопасности жильцов&#xa;6) CDC передаёт сырые данные в DWH&#xa;   без маскирования ПДн" vertex="1">
          <mxGeometry height="120" width="310" x="405" y="480" as="geometry" />
        </mxCell>
        <mxCell id="q-YAQTcvxLUxt3pqkwpD-37" edge="1" parent="1" source="conf_r1" style="strokeColor=#b85450;dashed=1;" target="conf_r1_why">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="conf_r2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;fontSize=11;fontStyle=1;strokeColor=#b85450;" value="🔴 Искажение данных&#xa;[КРИТИЧЕСКИЙ]" vertex="1">
          <mxGeometry height="50" width="220" x="450" y="800" as="geometry" />
        </mxCell>
        <mxCell id="q-YAQTcvxLUxt3pqkwpD-38" edge="1" parent="1" source="cat_conf" style="strokeColor=#b85450;strokeWidth=2;" target="conf_r2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="conf_r2_why" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffee;fontSize=10;" value="1) Клиенты видят чужие ФИО в ЛК&lt;br&gt;2) Нескоординированные точки&lt;br&gt;   регистрации → путаница профилей&lt;br&gt;3) API партнёров позволяют изменять&lt;br&gt;   данные чужих клиентов/ЖК&lt;br&gt;4) Искажение данных сделок → &lt;br&gt;   юридические последствия" vertex="1">
          <mxGeometry height="110" width="310" x="104" y="610" as="geometry" />
        </mxCell>
        <mxCell id="q-YAQTcvxLUxt3pqkwpD-39" edge="1" parent="1" source="conf_r2" style="strokeColor=#b85450;dashed=1;" target="conf_r2_why">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="conf_r3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;fontSize=11;fontStyle=1;strokeColor=#d6b656;" value="⚠️ Некачественные данные&#xa;[ЗНАЧИТЕЛЬНЫЙ]" vertex="1">
          <mxGeometry height="50" width="220" x="450" y="900" as="geometry" />
        </mxCell>
        <mxCell id="q-YAQTcvxLUxt3pqkwpD-40" edge="1" parent="1" source="cat_conf" style="strokeColor=#d6b656;strokeWidth=2;" target="conf_r3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="conf_r3_why" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffee;fontSize=10;" value="Несколько CRM (client-crm-app + CRM&#xa;собственников) без единого мастера&#xa;данных. Дублирование клиентов при&#xa;переходе покупатель → собственник.&#xa;Блокирует развитие новых сервисов" vertex="1">
          <mxGeometry height="80" width="300" x="730" y="900" as="geometry" />
        </mxCell>
        <mxCell id="q-YAQTcvxLUxt3pqkwpD-41" edge="1" parent="1" source="conf_r3" style="strokeColor=#d6b656;dashed=1;" target="conf_r3_why">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="conf_r4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;fontSize=11;fontStyle=1;strokeColor=#d6b656;" value="⚠️ Потеря данных&#xa;[ЗНАЧИТЕЛЬНЫЙ]" vertex="1">
          <mxGeometry height="50" width="220" x="450" y="990" as="geometry" />
        </mxCell>
        <mxCell id="q-YAQTcvxLUxt3pqkwpD-42" edge="1" parent="1" source="cat_conf" style="strokeColor=#d6b656;strokeWidth=2;" target="conf_r4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="conf_r4_why" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffee;fontSize=10;" value="Потеря данных онлайн-сделки →&#xa;срыв сделки и юридические&#xa;последствия. Потеря платёжных&#xa;данных → невозможность&#xa;подтвердить оплату ЖКУ.&#xa;Бэкапы есть, но RTO/RPO не указаны" vertex="1">
          <mxGeometry height="90" width="300" x="730" y="990" as="geometry" />
        </mxCell>
        <mxCell id="q-YAQTcvxLUxt3pqkwpD-43" edge="1" parent="1" source="conf_r4" style="strokeColor=#d6b656;dashed=1;" target="conf_r4_why">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="conf_r5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;fontSize=11;fontStyle=1;strokeColor=#d6b656;" value="⚠️ Обесценивание данных&#xa;[ЗНАЧИТЕЛЬНЫЙ]" vertex="1">
          <mxGeometry height="50" width="220" x="450" y="1080" as="geometry" />
        </mxCell>
        <mxCell id="q-YAQTcvxLUxt3pqkwpD-44" edge="1" parent="1" source="cat_conf" style="strokeColor=#d6b656;strokeWidth=2;" target="conf_r5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="conf_r5_why" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffee;fontSize=10;" value="При массовой утечке ПДн данные&#xa;становятся общедоступными →&#xa;теряют ценность для компании.&#xa;Необходимость перевыпуска данных&#xa;(смена контактов клиентами)" vertex="1">
          <mxGeometry height="80" width="300" x="730" y="1080" as="geometry" />
        </mxCell>
        <mxCell id="q-YAQTcvxLUxt3pqkwpD-45" edge="1" parent="1" source="conf_r5" style="strokeColor=#d6b656;dashed=1;" target="conf_r5_why">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="cat_sec" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;fontSize=14;fontStyle=1;strokeColor=#9673a6;" value="Секретные данные" vertex="1">
