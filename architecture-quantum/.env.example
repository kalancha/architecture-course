## Copy this file to ".env" and fill in your secrets.
## NEVER commit ".env" to git.

YANDEX_API_KEY=your_api_key_here
YANDEX_FOLDER_ID=your_folder_id_here

# Embeddings (must match between indexing and querying)
# EMBEDDING_MODEL_NAME=paraphrase-multilingual-MiniLM-L12-v2

# Routing
# ROUTE_NON_QUESTIONS_DIRECT=0

# Assignment 5: prompt-injection defenses
# DEFENSE_LEVEL=all  # none | pre | filter | sanitize | all

# Optional overrides
# YANDEX_MODEL=yandexgpt-lite
# YANDEX_MODEL_URI=gpt://<folder_id>/yandexgpt-lite
# YANDEX_TEMPERATURE=0.6
# YANDEX_MAX_TOKENS=2000
# YANDEX_TIMEOUT_S=60
# YANDEX_API_URL=https://llm.api.cloud.yandex.net/foundationModels/v1/completion
