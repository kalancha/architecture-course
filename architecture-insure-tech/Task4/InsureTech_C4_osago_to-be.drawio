                <mxCell id="multi-note" value="Сервисы работают в нескольких экземплярах.&#10;Состояние хранится в PostgreSQL и Redis, поэтому решение не зависит от конкретной реплики core-app или osago-aggregator." style="text;html=1;strokeColor=none;fillColor=none;fontSize=15;fontColor=#333333;align=left;verticalAlign=top;whiteSpace=wrap;" vertex="1" parent="1">
                    <mxGeometry x="1725" y="840" width="330" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="api-note" value="Web API в core-app:&#10;POST /api/osago/applications&#10;GET /api/osago/applications/{id}&#10;GET /api/osago/applications/{id}/offers&#10;GET /api/osago/applications/{id}/offers/stream - SSE" style="rounded=1;absoluteArcSize=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#5282ff;strokeWidth=1.4;fontSize=15;fontColor=#222222;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" vertex="1" parent="1">
